{
  "kind": "gridwork.agent",
  "id": "platform-engineer-agent",
  "name": "Gridwork Platform Engineer",
  "version": "0.2.0",
  "description": "Builds and verifies approved repository bootstrap, monorepo delivery infrastructure, containers and GitHub Actions.",
  "mode": "hybrid",
  "contract": "AGENT.md",
  "allowedWorkflows": [
    "repository-bootstrap",
    "delivery-infrastructure",
    "ci-failure-repair"
  ],
  "allowedSkills": [
    "monorepo-layout-design",
    "repository-bootstrap",
    "quality-command-contract",
    "docker-compose-environment-strategy",
    "github-actions-monorepo-ci",
    "github-actions-reusable-workflows",
    "changed-scope-detection",
    "ci-status-evaluation",
    "ci-failure-diagnosis",
    "container-build-and-verification",
    "github-rulesets-management",
    "github-environments-management",
    "deployment-verification",
    "rollback-planning",
    "github-actions-cicd",
    "github-cli",
    "diagnose-bug",
    "docker-compose-local-guidance",
    "nextjs-project-bootstrap",
    "nextjs-ci-quality-gates",
    "nextjs-container-build",
    "nextjs-e2e-testing",
    "springboot-project-bootstrap",
    "springboot-ci-quality-gates",
    "springboot-migration-testing",
    "springboot-container-build",
    "springboot-integration-testing",
    "fastapi-project-bootstrap",
    "fastapi-ci-quality-gates",
    "fastapi-migration-testing",
    "fastapi-container-build",
    "fastapi-integration-testing",
    "postgres-test-environment",
    "database-migration-verification",
    "handoff"
  ],
  "permissionProfile": "platform-assisted",
  "pathScopes": [
    "gridwork_factory_read",
    "factory_runtime_write",
    "delivery_infrastructure_write",
    "project_context_readonly"
  ],
  "policyRefs": [
    "../../policies/security-policy.md",
    "../../policies/logging-policy.md",
    "../../policies/path-scopes.md",
    "../../policies/agent-permissions.md",
    "../../policies/workspace-domains.md",
    "../../policies/human-gates.md",
    "../../policies/policy-precedence.md",
    "../../policies/delivery-infrastructure-policy.md"
  ],
  "handoffPolicy": "required_on_agent_or_session_transfer"
}
