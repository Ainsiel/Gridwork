{
  "kind": "gridwork.agent",
  "id": "verifier-agent",
  "name": "Gridwork Verifier Agent",
  "version": "0.1.0",
  "description": "Reviews implementation or PR evidence, tests, scope and policy compliance without modifying code.",
  "mode": "hybrid",
  "contract": "AGENT.md",
  "allowedWorkflows": [
    "verification-pr",
    "feature-pr-delivery",
    "release-promotion"
  ],
  "allowedSkills": [
    "github-cli",
    "github-issue-discovery",
    "diagnose-bug",
    "tdd",
    "integration-test-design",
    "integration-testing",
    "frontend-architecture-design",
    "frontend-state-strategy",
    "frontend-api-contract-consumption",
    "frontend-testing-strategy",
    "architecture-conformance-verification",
    "git-branch-management",
    "pull-request-lifecycle",
    "ci-status-evaluation",
    "quality-command-contract",
    "changed-scope-detection",
    "container-build-and-verification",
    "nextjs-ci-quality-gates",
    "nextjs-e2e-testing",
    "springboot-ci-quality-gates",
    "springboot-migration-testing",
    "springboot-integration-testing",
    "fastapi-ci-quality-gates",
    "fastapi-migration-testing",
    "fastapi-integration-testing",
    "postgres-test-environment",
    "database-migration-verification",
    "nextjs-frontend-guidance",
    "nextjs-app-router-architecture",
    "nextjs-auth-session-guidance",
    "nextjs-data-fetching-and-cache",
    "nextjs-ui-design",
    "nextjs-performance",
    "springboot-backend-guidance",
    "springboot-performance",
    "fastapi-backend-guidance",
    "fastapi-performance",
    "postgresql-persistence-guidance",
    "postgresql-performance",
    "dockerfile-authoring",
    "docker-compose-local-guidance",
    "docker-compose-optimization",
    "handoff"
  ],
  "permissionProfile": "verifier-assisted-readonly",
  "pathScopes": [
    "gridwork_factory_read",
    "factory_runtime_write",
    "project_context_readonly",
    "reports_write"
  ],
  "policyRefs": [
    "../../policies/security-policy.md",
    "../../policies/logging-policy.md",
    "../../policies/github-cli-policy.md",
    "../../policies/path-scopes.md",
    "../../policies/agent-permissions.md",
    "../../policies/human-gates.md",
    "../../policies/tdd-evidence-policy.md",
    "../../policies/git-policy.md",
    "../../policies/tool-allowlist.md",
    "../../policies/stack-skill-policy.md"
  ],
  "handoffPolicy": "required_on_agent_or_session_transfer"
}
