{
  "kind": "gridwork.agent",
  "id": "backlog-manager-agent",
  "name": "Gridwork Backlog Manager Agent",
  "version": "0.1.0",
  "description": "Maintains a unified view of local and GitHub backlog, answers backlog questions and prepares approved tasks for implementation.",
  "mode": "interactive",
  "contract": "AGENT.md",
  "allowedWorkflows": [
    "backlog-management",
    "backlog-task-delivery"
  ],
  "allowedSkills": [
    "backlog-management",
    "backlog-planning",
    "github-issue-discovery",
    "github-issue-publisher",
    "github-label-manager",
    "github-cli",
    "work-order-branch-lifecycle",
    "handoff"
  ],
  "permissionProfile": "backlog-manager-assisted",
  "pathScopes": [
    "gridwork_factory_read",
    "factory_runtime_write",
    "docs_backlog_write",
    "project_context_readonly"
  ],
  "policyRefs": [
    "../../policies/security-policy.md",
    "../../policies/logging-policy.md",
    "../../policies/github-cli-policy.md",
    "../../policies/github-labels.json",
    "../../policies/path-scopes.md",
    "../../policies/agent-permissions.md",
    "../../policies/workspace-domains.md",
    "../../policies/human-gates.md",
    "../../policies/policy-precedence.md",
    "../../policies/work-order-policy.md"
  ],
  "handoffPolicy": "required_on_agent_or_session_transfer"
}
