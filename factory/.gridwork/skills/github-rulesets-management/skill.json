{
  "kind": "gridwork.skill",
  "id": "github-rulesets-management",
  "name": "GitHub Rulesets Management",
  "version": "0.2.0",
  "description": "Plans and optionally applies approved branch rulesets and required checks using GitHub CLI.",
  "category": "github",
  "allowedAgents": ["platform-engineer-agent"],
  "allowedWorkflows": ["delivery-infrastructure"],
  "requiredInputs": ["branch_delivery_policy", "required_checks_plan"],
  "producedOutputs": ["github_rulesets_plan", "github_rulesets_result"],
  "artifactPaths": [".factory/runs/<run-id>/artifacts/github/"],
  "toolPolicyRefs": ["../../policies/github-cli-policy.md"],
  "humanGates": ["github_write", "strong_remote_action"],
  "permissionsInheritedOnly": true
}
