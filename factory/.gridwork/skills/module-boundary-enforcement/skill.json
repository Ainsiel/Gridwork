{
  "kind": "gridwork.skill",
  "id": "module-boundary-enforcement",
  "name": "Module Boundary Enforcement",
  "version": "0.1.0",
  "description": "Creates executable architecture tests that enforce approved module and dependency boundaries.",
  "category": "architecture-testing",
  "allowedAgents": ["architecture-foundation-agent"],
  "allowedWorkflows": ["architecture-foundation"],
  "requiredInputs": ["approved_dependency_rules", "confirmed_modules", "approved_test_commands"],
  "producedOutputs": ["architecture_tests", "boundary_test_evidence"],
  "artifactPaths": [".factory/runs/<run-id>/artifacts/testing/architecture/"],
  "toolPolicyRefs": ["../../policies/architecture-foundation-policy.md", "../../policies/tool-allowlist.md"],
  "humanGates": ["dependency_change", "unknown_command", "scope_change"],
  "permissionsInheritedOnly": true
}
