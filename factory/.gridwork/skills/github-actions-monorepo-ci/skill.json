{
  "kind": "gridwork.skill",
  "id": "github-actions-monorepo-ci",
  "name": "GitHub Actions Monorepo CI",
  "version": "0.2.0",
  "description": "Designs branch-aware monorepo CI gates for feature, develop, release and production flows.",
  "category": "cicd",
  "allowedAgents": ["platform-engineer-agent"],
