  "artifactPaths": [".factory/runs/<run-id>/artifacts/stack-guidance/frontend-performance/"],
  "toolPolicyRefs": ["../../../../policies/stack-skill-policy.md"],
  "humanGates": ["path_confirmation", "dependency_change", "cache_semantics_change"],
  "permissionsInheritedOnly": true,
  "generatesOnInit": false
}
