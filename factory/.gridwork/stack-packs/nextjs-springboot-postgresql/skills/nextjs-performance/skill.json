{
  "kind": "gridwork.skill",
  "id": "nextjs-performance",
  "name": "Next.js Performance",
  "version": "0.1.0",
  "description": "Measures and improves Next.js rendering, bundles, caching and Web Vitals without speculative optimization.",
  "category": "stack-performance",
