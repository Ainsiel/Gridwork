{
  "kind": "gridwork.skill",
  "id": "fastapi-backend-guidance",
  "name": "FastAPI Backend Guidance",
  "version": "0.1.0",
  "description": "Guides architecture, implementation and verification for an existing FastAPI backend.",
  "category": "stack-guidance",
  "allowedAgents": [
    "software-architect",
    "architecture-foundation-agent",
    "implementer-agent",
    "verifier-agent"
  ],
  "allowedWorkflows": [
    "architecture-ddd",
    "architecture-foundation",
    "tdd-implementation",
    "verification-pr"
  ],
  "requiredInputs": [
    "confirmed_fastapi_project",
    "confirmed_backend_paths",
    "detected_python_and_fastapi_versions"
