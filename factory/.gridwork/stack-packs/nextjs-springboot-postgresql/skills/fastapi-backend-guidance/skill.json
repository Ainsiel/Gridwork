    "fastapi_implementation_or_review"
  ],
  "artifactPaths": [
    ".factory/runs/<run-id>/artifacts/stack/fastapi/"
  ],
  "toolPolicyRefs": [
    "../../policies/test-commands.json",
    "../../policies/quality-commands.json",
    "../../../../policies/stack-skill-policy.md"
  ],
  "humanGates": [
    "dependency_change",
    "unknown_command",
    "secret_value_needed"
  ],
  "permissionsInheritedOnly": true,
  "generatesOnInit": false
}
